{
  "permissions": {
    "deny": [
      "Bash"
    ],
    "allow": [
      "Skill(codex:rescue)",
      "Skill(codex:rescue:*)",
      "Read(//tmp/**)",
      "Skill(codex-prompt-archive)",
      "Skill(codex-prompt-archive:*)",
      "Skill(git-workflow)",
      "Skill(git-workflow:*)",
      "mcp__rexec__check_host",
      "mcp__rexec__exec"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "model": "claude-opus-4-7[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/calendar-jp-grounding.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "theme": "auto"
}
