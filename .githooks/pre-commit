#!/bin/sh
# Ensure this git invocation was launched via scripts/commit-all.sh.
# The wrapper sets WORKSPACE_GIT_WRAPPER=1 in its environment.

set -eu

# Block Codex from committing even if it bypasses commit-all.sh.
# Resolve the guard relative to the repo root (hooks run from
# the repo's working directory, which may be a submodule).
_hook_guard="$(git rev-parse --show-superproject-working-tree 2>/dev/null || git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$_hook_guard" ] && [ -f "$_hook_guard/scripts/lib/codex-guard.sh" ]; then
    . "$_hook_guard/scripts/lib/codex-guard.sh"
elif [ -f "scripts/lib/codex-guard.sh" ]; then
    . scripts/lib/codex-guard.sh
fi
unset _hook_guard

# Block commits that stage files likely to contain secrets.
# .env.example and similar documentation files are allowed.
_sensitive_found=0
git diff --cached --name-only --diff-filter=ACR | while IFS= read -r f; do
    _base=$(basename "$f")
    case "$_base" in
        .env|.env.local|.env.production|.env.staging|.env.development)
            printf '!!! Blocked: staged file "%s" likely contains secrets.\n' "$f" >&2
            printf '    Use .env.example for committed templates.\n' >&2
            exit 10
            ;;
        *.pem|*.key|*.p12|*.pfx|*.jks|*.keystore)
            printf '!!! Blocked: staged file "%s" looks like key material.\n' "$f" >&2
            printf '    Key files must not be committed to the repository.\n' >&2
            exit 10
            ;;
        credentials.json|service-account*.json|*-credentials.json)
            printf '!!! Blocked: staged file "%s" looks like credentials.\n' "$f" >&2
            exit 10
            ;;
        id_rsa|id_ed25519|id_ecdsa|*.ppk)
            printf '!!! Blocked: staged file "%s" is an SSH private key.\n' "$f" >&2
            exit 10
            ;;
    esac
done
# The while-pipe runs in a subshell; capture its exit status.
# On POSIX sh, `set -e` doesn't propagate from the subshell,
# so we re-check with a second pass if the pipe succeeded.
git diff --cached --name-only --diff-filter=ACR | while IFS= read -r f; do
    _base=$(basename "$f")
    case "$_base" in
        .env|.env.local|.env.production|.env.staging|.env.development|\
        *.pem|*.key|*.p12|*.pfx|*.jks|*.keystore|\
        credentials.json|service-account*.json|*-credentials.json|\
        id_rsa|id_ed25519|id_ecdsa|*.ppk)
            exit 10
            ;;
    esac
done || {
    printf 'Commit aborted: sensitive file detected in staging area.\n' >&2
    exit 1
}

THRESHOLD=$((20 * 1024 * 1024))  # 20 MiB
changed=0
git diff --cached --name-only --diff-filter=A | while IFS= read -r f; do
    [ -f "$f" ] || continue
    size=$(wc -c < "$f")
    if [ "$size" -gt "$THRESHOLD" ]; then
        # Skip if already covered by an LFS pattern
        if ! git check-attr filter -- "$f" | grep -q 'filter: lfs'; then
            git lfs track "$f"
            git add .gitattributes
            git rm --cached "$f" >/dev/null
            git add "$f"   # re-stage so it goes through the LFS filter
        fi
    fi
done

if [ "${WORKSPACE_GIT_WRAPPER:-}" = "1" ]; then
    # Called through the wrapper. Proceed.
    echo "Good: Git called through the proper wrapper." >&2
    exit 0
fi

cat >&2 <<'EOF'
================================================================
  Commit blocked: git was not invoked via scripts/commit-all.sh

  This repository requires commits go through the wrapper, which
  runs pre-flight checks and enforces a signature and a sign-off.

  To bypass this hook for a legitimate reason:
      git commit --no-verify

  For rationale, see README.md § Development workflow.
================================================================
EOF
exit 1
