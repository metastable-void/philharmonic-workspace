target/
**/*.rs.bk
.DS_Store
.vscode/settings.json
._*

# Project-local Codex state (when CODEX_HOME points at .codex/):
# track only the committed config, not session/auth/cache state.
.codex/*
!.codex/config.toml

# Claude Code session-state files. Anything under .claude/ that
# represents ephemeral per-session state (lock files, caches) is
# ignored; committed tooling (settings.json, skills/, any local
# settings like settings.local.json) stays tracked via the
# negated entries below.
.claude/*.lock
.claude/.cache/
.claude/scheduled_tasks.lock

