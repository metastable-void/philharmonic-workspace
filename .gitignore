target/
# Separate target dir for `./scripts/xtask.sh` invocations (see
# the script's header and CONTRIBUTING.md §8). Keeping xtask
# builds out of the shared `target/` avoids target-lock
# contention with concurrent `cargo test` / Codex cargo runs,
# which can freeze workspace tooling (e.g. `commit-all.sh` →
# `print-audit-info.sh` → `cargo xtask web-fetch`) for the
# duration of the competing build.
target-xtask/
target-publish/
target-main/
target-release/

**/*.rs.bk
*.swp
*.swo
*~
.DS_Store
.vscode/settings.json
._*

# Project-local Codex state (when CODEX_HOME points at .codex/):
# track only the committed config, not session/auth/cache state.
.codex/*
!.codex/config.toml

# Claude Code state files under .claude/. Ignored: ephemeral
# per-session state (lock files, caches), and per-developer
# local overrides (settings.local.json — Claude Code's
# standard "personal settings for this project" file, not
# meant to travel). Tracked: settings.json (project-wide
# Claude Code config), skills/ (committed skill definitions),
# and hooks/ (PostToolUse / SessionStart / etc. hook scripts
# referenced from settings.json).
.claude/*.lock
.claude/settings.local.json
.claude/.cache/
.claude/scheduled_tasks.lock

# WebUI build intermediates (the committed artifacts live in
# philharmonic/webui/dist/ and are tracked; everything else is
# transient).
node_modules/

# mdBook build output
book/

# .env files
.env

/archives/*.tar.gz
/archives/*.tar.zst
